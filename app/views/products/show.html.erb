<p class="notice"><%= notice %></p>

<%= render @product %>

<div class="product-actions">
  <%= link_to "Edit this product", edit_product_path(@product), class: "btn edit-btn" %> 
  <%= link_to "Back to products", products_path, class: "btn back-btn" %>
  <%= link_to "Destroy this product", @product, method: :delete, class: "btn destroy-btn", data: { confirm: "Are you sure?" } %>
</div>

